# MindNet environment configuration
# Copy this file to .env and fill in your values.
# .env is listed in .gitignore — never commit credentials.

# SSH credentials (used when --username / --password flags are not passed)
NETMIND_USERNAME=admin
NETMIND_PASSWORD=cisco

# Enable secret for Cisco privileged mode (optional)
NETMIND_SECRET=

# Set to "true" to use the built-in mock device (no real SSH needed)
# Useful for local development, demos, and CI.
NETMIND_MOCK=false

# Default SSH port (override if your devices use non-standard port)
# NETMIND_PORT=22

# Default device type for Netmiko
# Options: cisco_ios, cisco_nxos, cisco_xr, arista_eos, juniper_junos
# NETMIND_DEVICE_TYPE=cisco_ios
